<%# Login Page %>
<div class="auth-page">
  <div class="auth-container">
    <%# Logo %>
    <div class="auth-header">
      <span class="auth-logo">Nook</span>
      <p class="auth-tagline">Discover your next favorite app</p>
    </div>

    <%# Flash Messages %>
    <% if flash[:alert] %>
      <div class="flash flash--alert mb-4">
        <p class="flash__message"><%= flash[:alert] %></p>
      </div>
    <% end %>
    <% if flash[:notice] %>
      <div class="flash flash--notice mb-4">
        <p class="flash__message"><%= flash[:notice] %></p>
      </div>
    <% end %>

    <%# Form %>
    <div class="auth-form-wrapper">
      <%= form_with url: session_path, class: "space-y-6" do |form| %>
        <div class="form-group">
          <%= form.label :email, "Email", class: "form-label" %>
          <%= form.email_field :email,
              required: true,
              autofocus: true,
              autocomplete: "username",
              placeholder: "you@example.com",
              value: params[:email],
              class: "form-input" %>
        </div>

        <div class="form-group">
          <%= form.label :password, "Password", class: "form-label" %>
          <%= form.password_field :password,
              required: true,
              autocomplete: "current-password",
              placeholder: "••••••••",
              maxlength: 72,
              class: "form-input" %>
        </div>

        <%= form.submit "Sign in", class: "btn btn--primary btn--full btn--xl" %>
      <% end %>

      <div class="text-center mt-6">
        <%= link_to "Forgot password?", new_password_path, class: "text-sm font-medium" %>
      </div>
    </div>

    <%# Sign Up CTA %>
    <p class="auth-footer">
      Don't have an account?
      <%= link_to "Sign up", new_user_path %>
    </p>
  </div>
</div>
