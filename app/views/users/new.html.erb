<%# Signup Page %>
<div class="auth-page">
  <div class="auth-container">
    <%# Logo %>
    <div class="auth-header">
      <span class="auth-logo">Nook</span>
      <p class="auth-tagline">Discover your next favorite app</p>
    </div>

    <%# Error Messages %>
    <% if @user.errors.any? %>
      <div class="error-list mb-4">
        <ul>
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# Form %>
    <div class="auth-form-wrapper">
      <%= form_with model: @user, class: "space-y-6" do |form| %>
        <div class="form-group">
          <%= form.label :email, "Email", class: "form-label" %>
          <%= form.email_field :email,
              required: true,
              autofocus: true,
              autocomplete: "email",
              placeholder: "you@example.com",
              class: "form-input" %>
        </div>

        <div class="form-group">
          <%= form.label :password, "Password", class: "form-label" %>
          <%= form.password_field :password,
              required: true,
              autocomplete: "new-password",
              placeholder: "••••••••",
              minlength: 8,
              class: "form-input" %>
          <p class="form-hint">Minimum 8 characters</p>
        </div>

        <div class="form-group">
          <%= form.label :password_confirmation, "Confirm Password", class: "form-label" %>
          <%= form.password_field :password_confirmation,
              required: true,
              autocomplete: "new-password",
              placeholder: "••••••••",
              class: "form-input" %>
        </div>

        <%= form.submit "Create Account", class: "btn btn--primary btn--full btn--xl" %>
      <% end %>
    </div>

    <%# Login CTA %>
    <p class="auth-footer">
      Already have an account?
      <%= link_to "Sign in", new_session_path %>
    </p>
  </div>
</div>
