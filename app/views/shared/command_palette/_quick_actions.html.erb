<div class="command-palette__section">
  <div class="command-palette__items command-palette__items--grid">
    <%= link_to root_path, class: "command-palette__action" do %>
      <div class="command-palette__action-icon command-palette__action-icon--primary">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-11.25a.75.75 0 00-1.5 0v2.5h-2.5a.75.75 0 000 1.5h2.5v2.5a.75.75 0 001.5 0v-2.5h2.5a.75.75 0 000-1.5h-2.5v-2.5z" clip-rule="evenodd" />
        </svg>
      </div>
      <span class="command-palette__action-label">New Chat</span>
    <% end %>

    <%= link_to stacks_path, class: "command-palette__action" do %>
      <div class="command-palette__action-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path d="M5.127 3.502L5.25 3.5h9.5c.041 0 .082 0 .123.002A2.251 2.251 0 0012.75 2h-5.5a2.25 2.25 0 00-2.123 1.502zM3.25 5A2.25 2.25 0 005.25 7.5h9.5A2.25 2.25 0 0017 5H3.25zM17 8.5H3.25A2.25 2.25 0 005.25 11h9.5A2.25 2.25 0 0017 8.5zM3.25 12H17a2.25 2.25 0 01-2.25 2.25h-9.5A2.25 2.25 0 013.25 12z" />
        </svg>
      </div>
      <span class="command-palette__action-label">My Stack</span>
    <% end %>

    <%= link_to chats_path, class: "command-palette__action" do %>
      <div class="command-palette__action-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm-.75-4.75a.75.75 0 011.5 0V5.75a.75.75 0 01-1.5 0v7.5zM8.25 9a.75.75 0 011.5 0v3.25a.75.75 0 01-1.5 0V9z" clip-rule="evenodd" />
        </svg>
      </div>
      <span class="command-palette__action-label">History</span>
    <% end %>
  </div>
</div>
