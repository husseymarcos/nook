<% unless Current.user.premium? %>
  <div class="command-palette__upgrade">
    <%= link_to billing_path, class: "command-palette__upgrade-link" do %>
      <div class="command-palette__upgrade-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-11.25a.75.75 0 00-1.5 0v2.5h-2.5a.75.75 0 000 1.5h2.5v2.5a.75.75 0 001.5 0v-2.5h2.5a.75.75 0 000-1.5h-2.5v-2.5z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="command-palette__upgrade-content">
        <span class="command-palette__upgrade-title">Upgrade to Premium</span>
        <span class="command-palette__upgrade-hint">Get unlimited searches</span>
      </div>
      <svg class="command-palette__upgrade-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
      </svg>
    <% end %>
  </div>
<% end %>
