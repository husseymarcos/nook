<%# Navigation with glassmorphism effect %>
<nav class="fixed top-0 left-0 right-0 z-50 bg-[#f6f6f6]/80 backdrop-blur-xl border-b border-transparent">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16 items-center">
      <%# Logo %>
      <%= link_to root_path, class: "flex items-center gap-2" do %>
        <span class="font-['Epilogue'] font-bold text-2xl tracking-tight text-[#004be2]">Nook</span>
      <% end %>

      <%# Desktop Navigation %>
      <div class="hidden md:flex items-center gap-8">
        <%= link_to "Chat", conversations_path, class: "text-[#444748] hover:text-[#004be2] font-medium transition-colors" %>
        <%= link_to "Stack", stacks_path, class: "text-[#444748] hover:text-[#004be2] font-medium transition-colors" %>
        <%= link_to "History", conversations_path, class: "text-[#444748] hover:text-[#004be2] font-medium transition-colors" %>
      </div>

      <%# User Menu %>
      <div class="flex items-center gap-4">
        <% if Current.user.premium? %>
          <span class="px-3 py-1 rounded-full bg-[#cce5ff] text-[#004be2] text-sm font-semibold">Premium</span>
        <% else %>
          <%= link_to billing_index_path, class: "hidden sm:inline-flex px-4 py-2 rounded-full bg-[#004be2] text-white font-semibold text-sm hover:bg-[#003bb8] transition-colors" do %>
            Upgrade
          <% end %>
        <% end %>

        <%= button_to session_path, method: :delete, class: "text-[#444748] hover:text-[#004be2] font-medium text-sm" do %>
          Sign out
        <% end %>
      </div>
    </div>
  </div>

  <%# Mobile Bottom Navigation %>
  <div class="md:hidden fixed bottom-0 left-0 right-0 bg-[#f6f6f6]/90 backdrop-blur-xl border-t border-[#e7e8e8] px-6 py-3 flex justify-around items-center z-50">
    <%= link_to conversations_path, class: "flex flex-col items-center gap-1 text-[#004be2]" do %>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
      </svg>
      <span class="text-xs font-medium">Chat</span>
    <% end %>

    <%= link_to stacks_path, class: "flex flex-col items-center gap-1 text-[#5f6368]" do %>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
      </svg>
      <span class="text-xs font-medium">Stack</span>
    <% end %>

    <%= link_to conversations_path, class: "flex flex-col items-center gap-1 text-[#5f6368]" do %>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span class="text-xs font-medium">History</span>
    <% end %>
  </div>
</nav>
