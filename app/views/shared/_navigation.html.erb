<%# Navigation %>
<nav class="nav">
  <div class="nav__container">
    <%# Logo %>
    <%= link_to root_path, class: "nav__logo" do %>
      Nook
    <% end %>

    <%# Desktop Navigation %>
    <div class="nav__links hidden-mobile">
      <%= link_to "Chat", new_chat_path, class: "nav__link" %>
      <%= link_to "Stack", stacks_path, class: "nav__link" %>
      <%= link_to "History", chats_path, class: "nav__link" %>
    </div>

    <%# User Menu %>
    <div class="nav__actions">
      <% if Current.user.premium? %>
        <span class="badge badge--premium hidden-mobile">Premium</span>
      <% else %>
        <%= link_to billing_index_path, class: "btn btn--primary btn--sm hidden-mobile" do %>
          Upgrade
        <% end %>
      <% end %>

      <%= button_to session_path, method: :delete, class: "btn btn--ghost btn--sm" do %>
        Sign out
      <% end %>
    </div>
  </div>
</nav>

<%# Mobile Bottom Navigation %>
<div class="mobile-nav">
  <%= link_to new_chat_path, class: "mobile-nav__link mobile-nav__link--active" do %>
    <svg class="mobile-nav__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>
    <span class="mobile-nav__label">Chat</span>
  <% end %>

  <%= link_to stacks_path, class: "mobile-nav__link" do %>
    <svg class="mobile-nav__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
    </svg>
    <span class="mobile-nav__label">Stack</span>
  <% end %>

  <%= link_to chats_path, class: "mobile-nav__link" do %>
    <svg class="mobile-nav__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <span class="mobile-nav__label">History</span>
  <% end %>
</div>
