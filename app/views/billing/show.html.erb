<%# Billing / Upgrade Page %>
<div class="page-container page-container--with-mobile-nav billing-page">
  <div class="content-wrapper">
    <%# Header %>
    <div class="billing-header">
      <h1 class="billing-header__title">Upgrade to Nook Premium</h1>
      <p class="billing-header__description">
        Unlock unlimited searches and get the most out of your app discovery journey
      </p>
    </div>

    <%# Pricing Card %>
    <div class="pricing-cards">
      <%# Monthly Plan %>
      <div class="pricing-card">
        <h3 class="pricing-card__plan">Monthly</h3>
        <div class="pricing-card__price">
          <span class="pricing-card__amount">$5</span>
          <span class="pricing-card__period">/month</span>
        </div>
        <ul class="pricing-card__features">
          <li>
            <svg class="pricing-card__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Unlimited searches
          </li>
          <li>
            <svg class="pricing-card__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Full conversation history
          </li>
          <li>
            <svg class="pricing-card__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            Unlimited stack size
          </li>
        </ul>
        <%= button_to billing_checkout_path(plan: "monthly"), class: "btn btn--primary btn--full btn--xl" do %>
          Subscribe
        <% end %>
      </div>
    </div>

    <%# Current Status %>
    <% if Current.user.premium? %>
      <div class="status-banner status-banner--premium mt-12">
        <p class="status-banner__text">
          You're on Premium until <%= Current.user.premium_until.strftime("%B %d, %Y") %>
        </p>
      </div>
    <% end %>
  </div>
</div>
