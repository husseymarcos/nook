<%# Message Bubble %>
<div class="flex <%= message.user? ? 'justify-end' : 'justify-start' %>" id="<%= dom_id(message) %>">
  <div class="max-w-[85%] md:max-w-[75%]">
    <%# Message Content %>
    <div class="<%= message.user? ? 'bg-[#004be2] text-white rounded-2xl rounded-br-sm' : 'bg-[#ffffff] text-[#191c1d] rounded-2xl rounded-bl-sm shadow-sm' %> px-5 py-3">
      <%# Parse and render recommendations if present %>
      <% if message.assistant? && (recommendations = message.recommendations).any? %>
        <div class="prose prose-sm max-w-none <%= message.user? ? 'prose-invert' : '' %>">
          <%= simple_format(message.content.split(/\d+\.\s*\*\*/).first.strip) %>
        </div>
        
        <%# Recommendations Grid %>
        <div class="mt-4 grid gap-3">
          <% recommendations.each_with_index do |rec, index| %>
            <div class="bg-[#f0f1f1] rounded-2xl p-4 <%= message.user? ? 'bg-white/10' : '' %>">
              <div class="flex items-start justify-between gap-3 mb-2">
                <h4 class="font-['Epilogue'] font-bold text-lg"><%= rec[:name] %></h4>
                <span class="px-2 py-1 rounded-full text-xs font-semibold bg-[#cce5ff] text-[#004be2]">
                  <%= rec[:pricing] %>
                </span>
              </div>
              <p class="text-sm <%= message.user? ? 'text-white/80' : 'text-[#5f6368]' %> mb-2">
                <%= rec[:description] %>
              </p>
              <div class="flex items-center justify-between">
                <span class="text-xs <%= message.user? ? 'text-white/60' : 'text-[#5f6368]' %>">
                  <%= rec[:platform] %>
                </span>
                
                <%# Add to Stack Button %>
                <% tool = Tool.find_by("lower(name) = ?", rec[:name].downcase) || Tool.create(name: rec[:name], description: rec[:description], platform: rec[:platform], category: "Other", is_default: false) %>
                <% unless Current.user.tools.include?(tool) %>
                  <%= button_to stacks_path(tool_id: tool.id), class: "text-xs px-3 py-1.5 rounded-full bg-[#004be2] text-white hover:bg-[#003bb8] transition-colors" do %>
                    + Add to Stack
                  <% end %>
                <% else %>
                  <span class="text-xs text-[#00c853] font-medium">✓ In Stack</span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="prose prose-sm max-w-none <%= message.user? ? 'prose-invert' : '' %>">
          <%= simple_format(message.content) %>
        </div>
      <% end %>
    </div>
    
    <%# Timestamp %>
    <p class="text-xs text-[#5f6368] mt-1 <%= message.user? ? 'text-right' : 'text-left' %>">
      <%= message.created_at.strftime("%I:%M %p") %>
    </p>
  </div>
</div>
