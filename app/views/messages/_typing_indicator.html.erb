<%# Typing Indicator %>
<div class="flex justify-start" id="typing-indicator">
  <div class="bg-[#ffffff] rounded-2xl rounded-bl-sm shadow-sm px-5 py-4">
    <div class="flex gap-1">
      <span class="w-2 h-2 rounded-full bg-[#004be2] animate-bounce"></span>
      <span class="w-2 h-2 rounded-full bg-[#004be2] animate-bounce" style="animation-delay: 0.1s"></span>
      <span class="w-2 h-2 rounded-full bg-[#004be2] animate-bounce" style="animation-delay: 0.2s"></span>
    </div>
  </div>
</div>
