<% if notice.present? %>
  <p style="color: green"><%= notice %></p>
<% end %>

<%= turbo_stream_from "chat_#{@chat.id}" %>

<div class="chat-page">
  <div class="chat-header">
    <h1 class="chat-header-title"><%= @chat.title.presence || "New Chat" %></h1>
    <div class="chat-header-meta">
      <button type="button" class="chat-header-logo-button" data-action="click->command-palette#open" title="Press Cmd+K to open menu">
        <%= image_tag "/logo.png", alt: "Nook logo", class: "chat-header-logo" %>
      </button>
      <div class="chat-header-hint">
        <kbd>Cmd</kbd>+<kbd>K</kbd>
      </div>
    </div>
  </div>

  <div class="messages-container" id="messages-container" data-controller="scroll">
    <div class="messages-list" id="messages">
      <% @chat.messages.where.not(id: nil).each do |message| %>
        <%= render message %>
      <% end %>
    </div>
  </div>

  <div class="chat-input-area">
    <div class="chat-input-area__container">
      <%= render "messages/form", chat: @chat, message: @message %>
    </div>
  </div>
</div>
