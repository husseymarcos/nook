<%= form_with(model: chat, url: chats_path, class: "form") do |form| %>
  <% if chat.errors.any? %>
    <div class="form-errors">
      <h2><%= pluralize(chat.errors.count, "error") %> prohibited this chat from being saved:</h2>
      <ul>
        <% chat.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :model, "Select AI model", class: "form-label" %>
    <%= form.select :model,
        options_for_select(@chat_models.map { |model| [model.label, model.id] }.unshift([default_model_display_name, nil]), @selected_model),
        {},
        class: "form-select" %>
  </div>

  <div class="form-group">
    <%= form.label :prompt, "Your message", class: "form-label" %>
    <%= form.text_field :prompt,
        class: "form-input",
        placeholder: "What would you like to discuss?",
        autofocus: true %>
  </div>

  <div class="form-actions">
    <%= form.submit "Start new chat", class: "btn btn--primary btn--full" %>
  </div>
<% end %>
