<% content_for :title, "New chat" %>

<div class="new-chat-page">
  <div class="new-chat-container">
    <%# Welcome State %>
    <div class="new-chat-welcome">
      <button type="button" class="new-chat-logo-button" data-action="click->command-palette#open" title="Press Cmd+K to open menu">
        <%= image_tag "/logo.png", alt: "Nook logo", class: "new-chat-logo" %>
      </button>
      <h1 class="welcome-state__title">Find your next favorite tool</h1>
      <p class="welcome-state__text">Tell me what you're building, and I'll recommend the best tools</p>
      <div class="new-chat-hint">
        <kbd>Cmd</kbd>+<kbd>K</kbd> to open menu
      </div>
    </div>

    <%# Input Form %>
    <div class="new-chat-input-area">
      <%= form_with(model: @chat, url: chats_path, class: "new-chat-form", data: { controller: "chat-form" }) do |form| %>
        <% if @chat.errors.any? %>
          <div class="form-errors">
            <h2><%= pluralize(@chat.errors.count, "error") %> prohibited this chat from being saved:</h2>
            <ul>
              <% @chat.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form.hidden_field :model, value: "gemini-2.5-flash" %>

        <div class="new-chat-input-wrapper">
          <%= form.text_area :prompt,
              class: "new-chat-input",
              placeholder: "What are you building? (Shift+Enter to send)",
              autofocus: true,
              autocomplete: "off",
              rows: 1,
              data: { chat_form_target: "input", action: "keydown->chat-form#handleKeydown" } %>
        </div>
      <% end %>
    </div>
  </div>
</div>
