<%# Stack Management Page %>
<div class="page-container page-container--with-mobile-nav stacks-page">
  <div class="content-wrapper">
    <%# Header %>
    <div class="stacks-header">
      <h1 class="stacks-header__title">Your Stacks</h1>
    </div>
    <p class="stacks-description">Organize your tools into different stacks for work, school, personal, and more.</p>

    <%# Create New Stack %>
    <%= form_with model: Stack.new, class: "create-stack-form" do |f| %>
      <%= f.text_field :name, placeholder: "New stack name (e.g., Work, School)...", class: "form-input", required: true %>
      <%= f.submit "Create Stack", class: "btn btn--primary" %>
    <% end %>

    <%# Stacks List %>
    <% if @stacks.any? %>
      <div class="stacks-list">
        <% @stacks.each do |stack| %>
          <%= link_to stack_path(stack), class: "stack-card" do %>
            <div class="stack-card__header">
              <h3 class="stack-card__name"><%= stack.name %></h3>
              <span class="stack-card__count"><%= stack.tools.count %> tools</span>
            </div>
            <div class="stack-card__tools">
              <% if stack.tools.any? %>
                <%= stack.tool_names.first(3).join(", ") %>
                <%= "+#{stack.tools.count - 3} more" if stack.tools.count > 3 %>
              <% else %>
                <span class="stack-card__empty">No tools yet</span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%# Empty State %>
      <div class="empty-state mb-10">
        <div class="empty-state__icon" style="background-color: var(--color-surface-hover);">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
          </svg>
        </div>
        <h3 class="empty-state__title">No stacks yet</h3>
        <p class="empty-state__text">Create your first stack to organize your tools</p>
      </div>
    <% end %>
  </div>
</div>
