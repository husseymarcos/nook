<%# Single Stack Page %>
<div class="page-container page-container--with-mobile-nav stack-show-page">
  <div class="content-wrapper">
    <%# Header %>
    <div class="stack-header">
      <%= link_to "← Back to Stacks", stacks_path, class: "stack-header__back" %>
      <div class="stack-header__main">
        <h1 class="stack-header__title"><%= @stack.name %></h1>
        <span class="badge badge--primary stack-header__count">
          <%= @stack.tools.count %>/20 Tools
        </span>
      </div>
      <%= button_to stack_path(@stack), method: :delete, class: "stack-header__delete", data: { confirm: "Delete this stack?" } do %>
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
      <% end %>
    </div>

    <%# Current Stack Tools %>
    <% if @stack.tools.any? %>
      <div class="stack-tools">
        <% @stack.tools.each do |tool| %>
          <div class="stack-tool">
            <div class="stack-tool__info">
              <div class="stack-tool__icon">
                <div class="stack-tool__icon-glow"></div>
                <span class="stack-tool__icon-text"><%= tool.name[0] %></span>
              </div>

              <div class="stack-tool__details">
                <h3 class="stack-tool__name"><%= tool.name %></h3>
                <p class="stack-tool__description"><%= tool.description %></p>
              </div>
            </div>

            <div class="stack-tool__actions">
              <span class="stack-tool__platform"><%= tool.platform %></span>
              <%= button_to stack_tool_path(@stack, tool), method: :delete, class: "stack-tool__remove" do %>
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <%# Empty State %>
      <div class="empty-state mb-10">
        <div class="empty-state__icon" style="background-color: var(--color-surface-hover);">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
          </svg>
        </div>
        <h3 class="empty-state__title">This stack is empty</h3>
        <p class="empty-state__text">Add tools to this stack from the options below</p>
      </div>
    <% end %>

    <%# Add Tools Section %>
    <div class="add-tools-section">
      <h2 class="add-tools-section__title">Add Tools</h2>

      <%# Default Tools Grid %>
      <% if @default_tools.any? %>
        <div class="default-tools">
          <% @default_tools.each do |tool| %>
            <%= button_to stack_tools_path(@stack, tool_id: tool.id), class: "default-tool" do %>
              <div class="default-tool__name"><%= tool.name %></div>
              <p class="default-tool__description"><%= tool.description %></p>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <%# Custom Tool Input %>
      <%= form_with url: stack_tools_path(@stack), class: "custom-tool-form" do |f| %>
        <%= f.text_field :tool_name,
            placeholder: "Add custom tool...",
            class: "form-input",
            required: true %>
        <%= f.submit "Add", class: "btn btn--primary" %>
      <% end %>
    </div>
  </div>
</div>
