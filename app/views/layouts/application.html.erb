<!DOCTYPE html>
<html class="dark">
  <head>
    <title><%= content_for(:title) || "Nook - Discover Your Next Favorite App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Nook">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Epilogue:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#f6f6f6] text-[#191c1d] font-['Plus_Jakarta_Sans'] antialiased">
    <% if authenticated? %>
      <%= render "shared/navigation" %>
    <% end %>

    <main class="min-h-screen">
      <%= yield %>
    </main>

    <%= render "shared/flash_messages" if flash.any? %>
  </body>
</html>
