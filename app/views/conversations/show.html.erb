<%# Chat Interface %>
<%= turbo_stream_from @conversation %>

<div class="chat-page">
  <%# Chat Header - Editable Title %>
  <div class="chat-header">
    <div class="chat-header__content">
      <div class="flex-1 min-w-0">
        <h1
          class="chat-header__title truncate"
          data-controller="editable-title"
          data-editable-title-url-value="<%= update_title_conversation_path(@conversation) %>"
          data-action="click->editable-title#edit"
        >
          <%= @conversation.title %>
        </h1>
        <p class="chat-header__meta"><%= @conversation.messages.count %> messages</p>
      </div>

      <%= button_to @conversation, method: :delete, class: "btn btn--danger btn--icon", data: { turbo_confirm: "Delete this conversation?" } do %>
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
      <% end %>
    </div>
  </div>

  <%# Messages Area %>
  <div class="messages-container" id="messages">
    <div class="messages-list">
      <% if @messages.any? %>
        <% @messages.each do |message| %>
          <%= render "messages/message", message: message %>
        <% end %>
      <% else %>
        <%# Welcome State %>
        <div class="welcome-state">
          <div class="welcome-state__icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
          <h2 class="welcome-state__title">What are you looking for?</h2>
          <p class="welcome-state__text">Describe your problem or what kind of app you need. I'll ask a few questions and recommend the best tools.</p>

          <%# Quick Prompts %>
          <div class="quick-prompts">
            <% ["I need a task manager", "Photo editing app", "Better note-taking tool", "Team collaboration"].each do |prompt| %>
              <%= button_to messages_path(conversation_id: @conversation.id), params: { message: { content: prompt } } do %>
                <%= prompt %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Typing Indicator (hidden by default, shown via Turbo) %>
      <div id="typing-indicator" class="hidden">
        <%= render "messages/typing_indicator" %>
      </div>
    </div>
  </div>

  <%# Input Area %>
  <div class="chat-input-area">
    <div class="chat-input-area__container">
      <%= form_with model: [@conversation, @message], class: "chat-input-form", id: dom_id(@conversation, :message_form) do |f| %>
        <div class="chat-input-wrapper">
          <%= f.text_area :content,
              rows: 1,
              class: "chat-input",
              placeholder: "Describe what you need...",
              data: {
                controller: "textarea-autogrow",
                action: "keydown->textarea-autogrow#submitOnEnter"
              } %>

          <%= f.button type: :submit, class: "chat-submit" do %>
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          <% end %>
        </div>
      <% end %>

      <%# Rate Limit Info %>
      <% unless Current.user.premium? %>
        <p class="rate-limit-info">
          <%= Current.user.searches_this_month %>/10 free searches this month
          <%= link_to "Upgrade", billing_index_path, class: "ml-1" %>
        </p>
      <% end %>
    </div>
  </div>
</div>
