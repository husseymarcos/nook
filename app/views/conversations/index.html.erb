<%# Conversations List / Dashboard %>
<div class="min-h-screen pt-20 pb-24 md:pb-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <%# Header %>
    <div class="mb-8">
      <h1 class="font-['Epilogue'] text-4xl font-bold text-[#191c1d] tracking-tight mb-2">
        Your Conversations
      </h1>
      <p class="text-[#5f6368]">Discover apps tailored to your needs</p>
    </div>

    <%# New Chat Button %>
    <%= link_to new_conversation_path, class: "inline-flex items-center gap-2 px-6 py-4 rounded-full bg-gradient-to-br from-[#004be2] to-[#809bff] text-white font-semibold text-lg shadow-lg shadow-[#004be2]/15 hover:shadow-xl hover:shadow-[#004be2]/25 transition-all mb-8" do %>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Start New Chat
    <% end %>

    <%# Conversations Grid %>
    <% if @conversations.any? %>
      <div class="grid gap-4">
        <% @conversations.each do |conversation| %>
          <%= link_to conversation, class: "block p-6 rounded-3xl bg-[#f0f1f1] hover:bg-[#e7e8e8] transition-colors group" do %>
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1">
                <h3 class="font-['Epilogue'] font-semibold text-lg text-[#191c1d] group-hover:text-[#004be2] transition-colors mb-1">
                  <%= conversation.title %>
                </h3>
                <p class="text-sm text-[#5f6368]">
                  <%= conversation.messages.count %> messages · <%= time_ago_in_words(conversation.updated_at) %> ago
                </p>
              </div>
              <svg class="w-5 h-5 text-[#5f6368] group-hover:text-[#004be2] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%# Empty State %>
      <div class="text-center py-16 px-6 rounded-3xl bg-[#f0f1f1]">
        <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-[#cce5ff] flex items-center justify-center">
          <svg class="w-8 h-8 text-[#004be2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </div>
        <h3 class="font-['Epilogue'] font-semibold text-xl text-[#191c1d] mb-2">No conversations yet</h3>
        <p class="text-[#5f6368] mb-6">Start your first chat to discover amazing apps</p>
        <%= link_to "Start Chat", new_conversation_path, class: "inline-flex px-6 py-3 rounded-full bg-[#004be2] text-white font-semibold hover:bg-[#003bb8] transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
