<%# Conversations List / Dashboard %>
<div class="page-container page-container--with-mobile-nav conversations-page">
  <div class="content-wrapper">
    <%# Header %>
    <div class="conversations-header">
      <h1 class="conversations-header__title">Your Conversations</h1>
      <p class="conversations-header__subtitle">Discover apps tailored to your needs</p>
    </div>

    <%# New Chat Button %>
    <%= link_to new_conversation_path, class: "btn btn--gradient btn--lg mb-8" do %>
      <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Start New Chat
    <% end %>

    <%# Conversations List %>
    <% if @conversations.any? %>
      <div class="conversations-list">
        <% @conversations.each do |conversation| %>
          <%= link_to conversation, class: "conversation-card" do %>
            <div class="flex justify-between items-start gap-4">
              <div class="flex-1 min-w-0">
                <h3 class="conversation-card__title"><%= conversation.title %></h3>
                <p class="conversation-card__meta">
                  <%= conversation.messages.count %> messages · <%= time_ago_in_words(conversation.updated_at) %> ago
                </p>
              </div>
              <svg class="conversation-card__arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%# Empty State %>
      <div class="empty-state">
        <div class="empty-state__icon">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </div>
        <h3 class="empty-state__title">No conversations yet</h3>
        <p class="empty-state__text">Start your first chat to discover amazing apps</p>
        <%= link_to "Start Chat", new_conversation_path, class: "btn btn--primary" %>
      </div>
    <% end %>
  </div>
</div>
