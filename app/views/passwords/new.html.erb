<%# Forgot Password Page %>
<div class="page-container">
  <div class="content-wrapper content-wrapper--narrow">
    <div class="page-header">
      <h1 class="page-title">Forgot your password?</h1>
    </div>

    <% if flash[:alert] %>
      <div class="flash flash--alert mb-4">
        <p class="flash__message"><%= flash[:alert] %></p>
      </div>
    <% end %>

    <%= form_with url: passwords_path, class: "space-y-4" do |form| %>
      <div class="form-group">
        <%= form.email_field :email,
            required: true,
            autofocus: true,
            autocomplete: "username",
            placeholder: "Enter your email address",
            value: params[:email],
            class: "form-input" %>
      </div>

      <%= form.submit "Email reset instructions", class: "btn btn--primary btn--full" %>
    <% end %>
  </div>
</div>
